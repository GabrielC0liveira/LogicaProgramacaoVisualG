Algoritmo "OrdemCrescente"
// Disciplina   : [Lógica de Programaçăo com VISUALG]
// Professor   : Jailson Costa
// Descriçăo   : Solicita dois números, coloca-os em ordem crescente e exibe o
// resultado.
// Autor(a)    : Gabriel Oliveira
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
 valor1: real
 valor2: real


Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
  escreva("Digite o primeiro número: ")
  leia(valor1)
  escreva("Digite um número diferente: ")
  leia(valor2)
  se valor1>valor2 entao
  escreval("Em ordem crescente: ",valor2, valor1)
  senao
  escreval("Em ordem crescente: ",valor1, valor2)
  fimse
Fimalgoritmo