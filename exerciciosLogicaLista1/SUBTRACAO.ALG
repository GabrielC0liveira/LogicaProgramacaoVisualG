Algoritmo "Subtracao"
// Disciplina   : [Lógica de Programaçăo com VISUALG]
// Professor   : Jailson Costa
// Descriçăo   : recebe dois numeros realiza a subtracao e mostra o resultado
// Autor(a)    : Gabrie Oliveira
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
  numero1: inteiro
  numero2: inteiro
  resultado: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
  escreva("Digitar um numero: ")
  leia(numero1)
  escreval("Digitar mais um numero: ")
  leia(numero2)
  resultado<- numero1 - numero2
  escreval("O resultado da calculo é: ", resultado)

Fimalgoritmo