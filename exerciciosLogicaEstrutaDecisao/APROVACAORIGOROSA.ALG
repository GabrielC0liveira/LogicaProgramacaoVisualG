Algoritmo "AprovacaoRigorosa"
// Disciplina  : [Lógica de Programaçăo com VISUALG]
// Professor   : Jailson Costa
// Descriçăo   : Leia as 3 notas bimestrais e o número de faltas. Se a média
// for >= 6 E as faltas forem < 15, exiba "Aprovado Direto". Se a média for >=
//  4 E as faltas forem < 15, exiba "Recuperaçăo". Senăo, exiba "Reprovado".
// Data atual  : 23/03/2026
Var
   // Seçăo de Declaraçőes das variáveis
   nota1, nota2, nota3, media: real
   faltas: inteiro


Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Digite o valor da sua primeira nota: ")
   leia(nota1)
   escreval("Digite o valor da sua segunda nota: ")
   leia(nota2)
   escreval("Digite o valor da sua terceira nota: ")
   leia(nota3)
   escreval("Digite seu número de faltas: ")
   leia(faltas)
   escreval("")

   media<-(nota1 + nota2 + nota3) / 3

   se (media>=6) e (faltas<15)  entao
      escreval("Aprovado Direto")
   senao
      se (media>=4) e (faltas<15)  entao
         escreval("Recuperaçăo")
      senao
         escreval("Reprovado")
      fimse
   fimse

Fimalgoritmo