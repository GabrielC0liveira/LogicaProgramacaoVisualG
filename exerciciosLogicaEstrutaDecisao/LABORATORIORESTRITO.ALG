Algoritmo "LaboratorioRestrito"
// Disciplina  : [Lógica de Programaçăo com VISUALG]
// Professor   : Jailson Costa
// Descriçăo   :Leia se o aluno possui agendamento (Verdadeiro/Falso) e se o
// professor responsável está presente (Verdadeiro/Falso). Permita a entrada
// (exiba "Acesso Autorizado") apenas se (Aluno tem agendamento OU Professor
// presente) E NĂO houver manutençăo no laboratório (leia esta variável
// booleana também).
// Data atual  : 23/03/2026
Var
   // Seçăo de Declaraçőes das variáveis

   agendamento, professor, manutencao: logico


Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("O aluno possui Agendamento: ")
   leia(agendamento)
   escreval("O professor está presente: ")
   leia(professor)
   escreval("O laboratorio está em manutençăo: ")
   leia(manutencao)
   escreval("")



   se (agendamento ou professor) e (nao manutencao) entao
      escreval("Acesso autorizado")
   senao
         escreval("Acesso negado")
      fimse


Fimalgoritmo