Algoritmo "ExRepeticaoRepita"
// Disciplina   : [Lógica de Programaçăo com VISUALG]
// Professor   : Jailson Costa
// Descriçăo   : Teste da funçăo repita
// até 500
// Autor(a)    : Gabriel Oliveira
// Data atual  : 30/03/2026
Var
   // Seçăo de Declaraçőes das variáveis
    contador: inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...

   repita
   escreval(contador)
   contador<- contador+1
   ate contador > 10



Fimalgoritmo