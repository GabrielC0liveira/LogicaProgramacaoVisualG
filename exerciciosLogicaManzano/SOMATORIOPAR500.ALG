Algoritmo "somatoriopar500"
// Disciplina   : [Lógica de Programaçăo com VISUALG]
// Professor   : Jailson Costa
// Descriçăo   : Programa que apresenta o somatório da soma dos numeros pares
// até 500
// Autor(a)    : Gabriel Oliveira
// Data atual  : 30/03/2026
Var
   // Seçăo de Declaraçőes das variáveis
   soma, contador: inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   contador<- 1
   enquanto contador <501 faça
      se (contador mod 2 = 0) entao
         soma<- soma+contador
      fimse
      contador<- contador+1
   fimenquanto

   escreval("O valor da soma dos números pares de 1 a 500 é: ",soma)

Fimalgoritmo